{
  "name": "oref-cloudflare-worker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create oref-db",
    "db:migrate:local": "wrangler d1 execute oref-db --local --file=./db/schema.sql",
    "db:migrate": "wrangler d1 execute oref-db --remote --file=./db/schema.sql",
    "db:seed:local": "wrangler d1 execute oref-db --local --file=./db/seed.sql",
    "db:seed": "wrangler d1 execute oref-db --remote --file=./db/seed.sql"
  },
  "devDependencies": {
    "wrangler": "latest"
  }
}
